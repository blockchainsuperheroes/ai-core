---
import nav from '../data/navigation.json';
---
<header class="sticky top-0 z-50 bg-base/90 backdrop-blur-md border-b border-white/5">
  <!-- Utility bar -->
  <div class="border-b border-white/5 bg-base-light/50">
    <div class="container-narrow flex items-center justify-end gap-4 py-1.5 text-xs">
      {nav.utility.map((link) => (
        <a href={link.href} target="_blank" rel="noopener" class="text-gray-500 hover:text-accent transition-colors flex items-center gap-1">
          {link.label}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      ))}
    </div>
  </div>

  <!-- Main nav -->
  <nav class="container-narrow">
    <div class="flex items-center justify-between py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-xl font-bold text-white">ERC-8170</span>
        <span class="text-xs text-gray-500 hidden sm:inline border border-white/10 rounded px-1.5 py-0.5">draft</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {nav.main.map((link) => (
          <a href={link.href} class="px-3 py-2 text-sm text-gray-400 hover:text-white rounded-md transition-colors hover:bg-white/5">
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-400 hover:text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-1">
        {nav.main.map((link) => (
          <a href={link.href} class="px-3 py-2 text-sm text-gray-400 hover:text-white rounded-md transition-colors hover:bg-white/5">
            {link.label}
          </a>
        ))}
        <hr class="border-white/10 my-2" />
        {nav.utility.map((link) => (
          <a href={link.href} target="_blank" rel="noopener" class="px-3 py-2 text-xs text-gray-500 hover:text-accent transition-colors flex items-center gap-1">
            {link.label}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
